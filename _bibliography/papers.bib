@inproceedings{yu2020,
  abbr={IEIE},
  title={Convolutional Neural Network Model Optimization for Single Channel Sleep Electroencephalogram Analysis},
  abstract={Sleep  is  very  important  for  staying  in  a  healthy condition.  
  Research  on  sleep  has  been  conducted intensively in recent years. 
  Sleep scoring has been conducted by sleep experts with polysomnography which is complex process. 
  Estimating sleep patterns with single channel EEG(Electroencephalogram) is 
  one  of  the  methods  to  automate  the  process  for sleep analysis. 
  An CNN (Convolutional Neural Network) model was used in sleep scoring. 
  Additionally,  the  CNN  model  was  optimized  with Bayesian Optimization and Hyperband (BOHB). 
  The accuracy from the optimized model was higher than the accuracy from empirically designed model.},
  author={Hyunsoo Yu and Seungwoo Han and Cheolsoo Park},
  booktitle={The Institute of Electronics and Information Engineers Summer Conference},
  pdf={https://www.dbpia.co.kr/journal/articleDetail?nodeId=NODE10448123},
  pages={1205--1208},
  year={2020}
}

@inproceedings{key,
  abbr={KOSOMBE},
  title={Reinforcement Learning Algorithm for Blood Pressure Estimation using ECG and PPG Signals},
  abstract={Blood pressure is one of the major bio-signal information which indicates one’s health
  condition. Especially, it is closely related to major cardiovascular diseases such as heart attack.
  So far, ECG and PPG features which contain heart activities in the form of characteristic signals
  for blood pressure has been studied constantly. However, there were some difficulties for
  choosing distinctive features which has high correlation to blood pressure. In this paper, we
  designed a reinforcement learning algorithm model such as Deep Q-Network (DQN) for high-
  costly feature extraction in order to estimate blood pressure. Finally, we evaluated
  performance by comparing the accuracy of the DQN and linear regression.},
  author={Seungwoo Han and Heesang Eom and Taeheum Cho and Cheolsoo Park},
  booktitle={The Korean Society of Medical & Biological and Engineering Spring Conference},
  year={2019}
}

@article{kang2023gan,
  abbr={BMEL},
  title={GAN-based patient information hiding for an ECG authentication system},
  abstract={Various biometrics such as the face, irises, and fingerprints, which can be obtained in a relatively simple way in modern society, are used in personal authentication systems to identify individuals. 
  These biometric data are extracted from an individual’s physiological data and yield high performance in identifying an individual using unique data patterns. 
  Biometric identification is also used in portable devices such as mobile devices because it is more secure than cryptographic token-based authentication methods. 
  However, physiological data could include personal health information such as arrhythmia related patterns in electrocardiogram (ECG) signals. 
  To protect sensitive health information from hackers, the biomarkers of certain diseases or disorders that exist in ECG signals need to be hidden. 
  Additionally, to implement the inference models for both arrhythmia detection and personal authentication in a mobile device, a lightweight model such as a multi-task deep learning model should be considered. 
  This study demonstrates a multi-task neural network model that simultaneously identifies an individual’s ECG and arrhythmia patterns using a small network. 
  Finally, the computational efficiency and model size of the single-task and multi-task models were compared based on the number of parameters. 
  Although the multi-task model has 20,000 fewer parameters than the single-task model, they yielded similar performance, which demonstrates the efficient structure of the multi-task model.},
  author={Kang, Youngshin and Yang, Geunbo and Eom, Heesang and Han, Seungwoo and Baek, Suwhan and Noh, Seungil and Shin, Youngjoo and Park, Cheolsoo},
  journal={Biomedical Engineering Letters},
  volume={13},
  number={2},
  pages={197--207},
  year={2023},
  pdf={https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10130315/},
  publisher={Springer}
}

